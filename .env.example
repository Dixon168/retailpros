# RetailPOS 环境变量配置
# 复制此文件为 .env.local，填入真实值
# ⚠️ 不要将 .env.local 提交到 Git

# ── Supabase ──
# 在 supabase.com → Project Settings → API 找到这两个值
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ── Stripe ──
# 在 dashboard.stripe.com → Developers → API keys 找到
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...your-stripe-key

# ── App Config ──
VITE_APP_NAME=RetailPOS
VITE_APP_URL=https://your-domain.com
